# Build-time (Vite). Copy to `.env` for local dev or set in GitHub Actions secrets for Pages.
#
# GitHub Pages project URL: https://<user>.github.io/<repo>/
# CI sets VITE_BASE_PATH=/repo-name/ automatically.
#
# IMPORTANT: GitHub Pages is HTTPS. The listener URL MUST be https://... or browsers block
# API/EventSource (mixed content). Use TLS on the VM (nginx + Let's Encrypt), Cloudflare Tunnel,
# or an HTTPS load balancer — then point this at that URL.

VITE_LISTENER_API_URL=https://listener.example.com
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Local only — omit in CI (workflow sets this from the repository name):
# VITE_BASE_PATH=/your-repo-name/
