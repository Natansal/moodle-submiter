# Build-time (Vite). Copy to `.env` for local dev or set in GitHub Actions secrets for Pages.
#
# GitHub Pages project URL: https://<user>.github.io/<repo>/
# CI sets VITE_BASE_PATH=/repo-name/ automatically.

VITE_LISTENER_API_URL=https://YOUR_VM_OR_DOMAIN:3001
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=

# Local only — omit in CI (workflow sets this from the repository name):
# VITE_BASE_PATH=/your-repo-name/
