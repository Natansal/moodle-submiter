# Copy to /etc/atent/listener.env on the VM (chmod 600).
# Runtime: listener systemd service.

NODE_ENV=production

# Many small GCP VMs have no working IPv6 route; Supabase DNS can return IPv6 first → Prisma ENETUNREACH.
# Prefer IPv4 when connecting to Postgres:
NODE_OPTIONS=--dns-result-order=ipv4first

PORT=3001
# Bind address (default 0.0.0.0 — required for GCP VM / Docker)
# HOST=0.0.0.0

# Must match the GitHub Pages origin (scheme + host only — no /repo path).
# Browser Origin for https://<user>.github.io/<repo>/ is https://<user>.github.io
CLIENT_ORIGIN=https://YOUR_USERNAME.github.io

# Supabase (Auth middleware validates Bearer tokens from the web client)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — Prisma / Baileys auth persistence.
#
# Supabase direct host db.<project>.supabase.co is usually IPv6-only → IPv4-only VMs need the
# shared pooler in SESSION mode (Dashboard → Connect → Session / “Session pooler”):
#   - Host: aws-0-<region>.pooler.supabase.com
#   - Port: 5432  (session pooler — not 6543; transaction mode conflicts with Prisma prepared stmts)
#   - User: postgres.<PROJECT_REF>  (must include project ref — not plain "postgres")
# Password special characters must be URL-encoded in the URL.
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# TLS to Postgres (pooler uses valid public CAs). If logs show P1011 / TlsConnectionError /
# "self-signed certificate in certificate chain", the VM's CA bundle is often stale or incomplete:
#   sudo apt-get update && sudo apt-get install -y ca-certificates
# Optional: Supabase Dashboard → Database → download SSL cert and point Node at it:
#   NODE_EXTRA_CA_CERTS=/etc/ssl/supabase-ca.crt
# Debugging only — disables certificate verification (insecure):
# DATABASE_SSL_REJECT_UNAUTHORIZED=0

# Upstash Redis (locks + settings)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Same 32-byte key as worker + client (base64)
CREDENTIALS_ENCRYPTION_KEY=
