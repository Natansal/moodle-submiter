# Copy to /etc/atent/listener.env on the VM (chmod 600).
# Runtime: listener systemd service.

NODE_ENV=production
PORT=3001
# Bind address (default 0.0.0.0 — required for GCP VM / Docker)
# HOST=0.0.0.0

# Must match the GitHub Pages origin exactly (scheme + host, no trailing slash).
# Example: https://yourname.github.io
CLIENT_ORIGIN=https://YOUR_USERNAME.github.io

# Supabase (Auth middleware validates Bearer tokens from the web client)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Postgres — Prisma / Baileys auth persistence (e.g. Supabase pooled connection string)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Upstash Redis (locks + settings)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Same 32-byte key as worker + client (base64)
CREDENTIALS_ENCRYPTION_KEY=
